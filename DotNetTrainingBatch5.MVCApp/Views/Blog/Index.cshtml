@model List<TblBlog>

<table>
    <thead>
        <tr>
            <th>No.</th>
            <th>Blog ID</th>
            <th>Blog Title</th>
            <th>Blog Content</th>
            <th>Blog Author</th>
        </tr>
    </thead>
    <tbody>
        @for (int i = 0; i < Model.Count; i++)
        {
            <tr>
                <td>@(i + 1)</td>
                <td>@Model[i].BlogId</td>
                <td>@Model[i].BlogTitle</td>
                <td>@Model[i].BlogContent</td>
                <td>@Model[i].BlogAuthor</td>
            </tr>
        }
    </tbody>
    @* 50Min *@
</table>